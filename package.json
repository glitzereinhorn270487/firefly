    "dev:webhook": "ts-node src/webhook_handler.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.84.0",
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "node-fetch": "^2.6.7"
  },
  "devDependencies": {
    "ts-node": "^10.9.1",
    "typescript": "^5.4.2"
  }
}
