{
  "name": "odyssee-listener",
  "version": "0.1.0",
  "description": "Listener and webhook receiver for Raydium events",
  "main": "dist/listener.js",
  "scripts": {
    "build": "npm run build:all",
    "build:all": "tsc -p tsconfig.node.json",
    "build:listener": "tsc -p tsconfig.node.json",
    "start:listener": "node dist/listener.js",
    "start:webhook": "node dist/webhook_handler.js",
    "start:metrics": "node dist/metrics/health.js",
    "export:logs": "./scripts/export_logs.sh",
    "dev:listener": "ts-node -P tsconfig.node.json src/listener.ts",
    "dev:webhook": "ts-node -P tsconfig.node.json src/webhook_handler.ts",
    "dev:metrics": "ts-node -P tsconfig.node.json src/metrics/health.ts",
    "dev:raydium-example": "ts-node -P tsconfig.node.json examples/raydium-listener-example.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "echo 'Linting not configured'",
    "lint:fix": "echo 'Linting not configured'"

  },
  "dependencies": {
    "@solana/web3.js": "^1.84.0",
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "node-fetch": "^2.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.0",
    "jest": "^30.1.1",
    "pino": "^9.9.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.2"
  }
}
