# Raydium paper-mvp example environment variables (opt-in)
# Leave empty to use local stubs/defaults for review

# Optional RPC provider (QuickNode, Alchemy, etc.)
RPC_URL=

# Optional Redis connection for durable queues
REDIS_URL=

# Webhook receiver defaults
WEBHOOK_PORT=3000
WEBHOOK_PATH=/raydium-webhook

# Optional logging level
LOG_LEVEL=info
