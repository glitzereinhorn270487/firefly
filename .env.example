# QuickNode (Solana) RPC URL (use your QuickNode Solana HTTP endpoint)
QUICKNODE_RPC_URL=https://solana-mainnet.quicknode.pro/your-key/

# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=https://us1-prd-upstash-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Telegram notifications
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# Paper trading / risk / limits
PAPER_TRADING=true
PAPER_INVEST_USD=50
GLOBAL_MAX_INVESTMENT_USD=15000
PAPER_TRADER_START_USD=1000

# Misc
NODE_ENV=production
LOG_LEVEL=info
VERCEL=true