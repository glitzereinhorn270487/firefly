# RPC WebSocket endpoint (required)
RPC_WSS=wss://your-quicknode-endpoint-here/websocket

# Webhook URL to forward events to (required)
WEBHOOK_URL=https://your-webhook.example.com/webhook

# Bearer token for outgoing webhook requests (optional)
WEBHOOK_AUTH=your-outgoing-bearer-token

# Server port for webhook receiver (default: 3000)
PORT=3000

# Rate limit for getParsedTransaction calls per second (default: 5)
MAX_GETTX_PER_SEC=5

# Upstash Redis configuration (optional - falls back to in-memory if not set)
UPSTASH_REDIS_REST_URL=https://your-redis-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token