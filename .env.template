# Upstash Redis URL and Token
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# DEXScreener API key (optional) - used for token discovery
DEXSCREENER_API_KEY=

# QuickNode / RPC endpoint (paper/live)
QUICKNODE_URL=

# GoPlus Security API Key (optional). If not present, heuristics will be used.
GOPLUS_API_KEY=

# Telegram integration (dashboard-managed only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Global flags
BOT_OFF=false            # if true, bot will not open new positions but will manage existing ones
PAPER_MODE=true         # run in paper (simulation) mode

# Logging configuration
LOG_TO_TEXT=true        # write logs to logs/trades.log (one JSON object per line)
LOG_TO_REDIS=false      # also write logs to Redis list (trade:logs)
LOG_RETENTION_DAYS=90   # trim Redis logs after this many days if LOG_TO_REDIS=true

# Investment sizing (enforced rules)
MIN_INVESTMENT_USD=15               # absolute minimum investment (hard floor)
DEFAULT_MIN_INVESTMENT_USD=20       # default minimum used for small capital scenarios

# ScoreX thresholds (defaults, can be overridden via dashboard)
MIN_SCORE_TO_CONSIDER=300
MIN_SCORE_TO_EXECUTE_PAPER=400
MIN_SCORE_TO_EXECUTE_LIVE=600

# Alpha Tuner
ALPHA_TUNER_ENABLED=true    # enable the built-in alpha tuner UI / backend endpoints

# Telegram notification settings are controlled by the dashboard only
TELEGRAM_DASHBOARD_ONLY=true

# Upstash/Redis DB keys used by the system (we will read/write these keys)
# Note: 'bannednames' is for absolute/permanent or timed bans and does not contain tiered signals.
UPSTASH_DB_KEYS=db:insider,db:smartmoney,db:walletcluster,db:viralx,db:narrativemaker,db:redflag,db:bannednames,db:teaminsider

# Logging location (local file)
LOG_FILE_PATH=logs/trades.log

# Misc
LOG_ROTATE_DAILY=true