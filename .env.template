POLICY_MOMENTUM_RIDE_DERISK_AMOUNT_PCT=0.3
POLICY_MOMENTUM_RIDE_TRAILING_STOP_PCT=-0.25
POLICY_MOMENTUM_RIDE_VOLATILITY_FACTOR=2.0
POLICY_MOMENTUM_RIDE_STAGNATION_SENSITIVITY=600

# Policy presets - Volatility Ride
POLICY_VOLATILITY_RIDE_DERISK_TARGET_PCT=1.0
POLICY_VOLATILITY_RIDE_DERISK_AMOUNT_PCT=0.25
POLICY_VOLATILITY_RIDE_TRAILING_STOP_PCT=-0.35
POLICY_VOLATILITY_RIDE_VOLATILITY_FACTOR=3.0
POLICY_VOLATILITY_RIDE_STAGNATION_SENSITIVITY=900

# =============================================================================
