# Odyssee (Firefly) Environment Configuration Template
# Copy this file to .env and configure the values for your environment

# =============================================================================
# UPSTASH REDIS CONFIGURATION
# =============================================================================
# Upstash Redis REST API URL - Used for caching and data storage
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io

# Upstash Redis REST API Token - Authentication for Redis operations
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# =============================================================================
# DEXSCREENER API CONFIGURATION  
# =============================================================================
# DEXScreener API key for token data and market information
DEXSCREENER_API_KEY=your_dexscreener_api_key_here

# DEXScreener API base URL (default: https://api.dexscreener.com)
DEXSCREENER_API_BASE=https://api.dexscreener.com

# =============================================================================
# QUICKNODE SOLANA RPC CONFIGURATION
# =============================================================================
# QuickNode Solana RPC HTTP endpoint URL
QUICKNODE_RPC_URL=https://solana-mainnet.quicknode.pro/your-key/

# QuickNode Solana WebSocket endpoint for real-time data
RPC_WSS=wss://solana-mainnet.quicknode.pro/your-key/

# =============================================================================
# QUICKNODE WEBHOOK CONFIGURATION
# =============================================================================
# QuickNode webhook HMAC secret for signature verification (production recommended)
QUICKNODE_WEBHOOK_SECRET=your_quicknode_webhook_secret_here

# Raydium program IDs whitelist (comma-separated, defaults to Raydium AMM)
RAYDIUM_PROGRAM_IDS=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8

# Raydium factory addresses whitelist (comma-separated, defaults to Raydium AMM)
RAYDIUM_FACTORY_ADDRESSES=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8

# Token whitelist (comma-separated mints, leave empty to allow all tokens)
TOKEN_WHITELIST_MINTS=So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Legacy token-based authentication (use QUICKNODE_WEBHOOK_SECRET instead)
QN_WEBHOOK_TOKEN=your_legacy_webhook_token

# Allow unsigned webhooks (development only - set to 1 to bypass signature verification)
QN_ALLOW_UNSIGNED=0

# =============================================================================
# GOPLUS SECURITY API CONFIGURATION
# =============================================================================
# GoPlus API key for token security analysis
GOPLUS_API_KEY=your_goplus_api_key_here

# GoPlus API base URL (default: https://api.gopluslabs.io)  
GOPLUS_API_BASE=https://api.gopluslabs.io

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=7633687305:AAEvjcLhxxxxxxxxxX8jHLK-QuMiyMOaPiSQ

# Telegram Chat ID where notifications will be sent
TELEGRAM_CHAT_ID=7590980638

# Alternative environment variables for Telegram
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# =============================================================================
# BOT CONTROL FLAGS
# =============================================================================
# Enable/disable bot trading functionality
BOT_ACTIVE=true

# Debug token for accessing debug endpoints
DEBUG_TOKEN=your_debug_token_here

# =============================================================================
# PAPER TRADING CONFIGURATION
# =============================================================================
# Enable paper trading mode (simulated trades)
PAPER_TRADING=true

# Starting USD amount for paper trader
PAPER_TRADER_START_USD=1000

# Investment amount per trade in paper mode
PAPER_INVEST_USD=50

# Global maximum investment limit in USD
GLOBAL_MAX_INVESTMENT_USD=15000

# Maximum first buyer positions allowed
PAPER_MAX_FIRSTBUYER_SLOTS=3

# Stagnation sweep interval in minutes
PAPER_STAG_MIN=5

# =============================================================================
# TRADING RULES AND THRESHOLDS
# =============================================================================
# Minimum volume in USD for 1-minute window
RULE_MIN_VOL_1M=50

# Minimum number of buyers in 1-minute window
RULE_MIN_BUYS_1M=1

# =============================================================================
# SCOREX THRESHOLDS AND CONFIGURATION
# =============================================================================
# Alpha Potential (AP) calculation weights
SCOREX_GINI_WEIGHT=0.3
SCOREX_TOP10_WEIGHT=0.4  
SCOREX_SOCIAL_WEIGHT=0.3

# Confidence Score (KS) thresholds
SCOREX_MIN_SOCIAL_CONFIDENCE=0.1
SCOREX_MIN_MARKET_CONFIDENCE=0.1

# Risk Factor (RF) thresholds
SCOREX_LIQUIDITY_AGE_THRESHOLD_HOURS=24
SCOREX_MAX_RISK_FACTOR=10000

# Final Score calculation bounds
SCOREX_MIN_FINAL_SCORE=0
SCOREX_MAX_FINAL_SCORE=1000

# Category multipliers for investment sizing
SCOREX_INSIDER_MULTIPLIER=1.25
SCOREX_NEWBORN_MULTIPLIER=1.0
SCOREX_MOMENTUM_MULTIPLIER=0.75
SCOREX_MOONSHOT_SHORT_MULTIPLIER=1.0

# Investment sizing parameters
SCOREX_GLOBAL_CAPITAL_FACTOR=0.02
SCOREX_MIN_FLOOR_USD=2

# Policy presets - Quick Scalp
POLICY_QUICK_SCALP_DERISK_TARGET_PCT=0.25
POLICY_QUICK_SCALP_DERISK_AMOUNT_PCT=0.5
POLICY_QUICK_SCALP_TRAILING_STOP_PCT=-0.15
POLICY_QUICK_SCALP_VOLATILITY_FACTOR=1.5
POLICY_QUICK_SCALP_STAGNATION_SENSITIVITY=300

# Policy presets - Momentum Ride  
